{
  "name": "remote-claude-code",
  "version": "0.1.0",
  "type": "module",
  "description": "Self-hosted tool to remotely control Claude Code from your phone via Cloudflare Tunnel + PWA",
  "keywords": ["claude", "claude-code", "remote", "anthropic", "ai", "cli"],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "rcc": "cli/index.ts"
  },
  "files": [
    "cli/",
    "server/",
    "dist/",
    "public/"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --watch server/index.ts",
    "dev:client": "bunx vite dev",
    "build": "bunx vite build",
    "start": "bun run server/index.ts",
    "postinstall": "node node_modules/cloudflared/lib/cloudflared.js install 2>/dev/null || true",
    "setup": "bun install && bunx vite build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "@anthropic-ai/claude-agent-sdk": "^0.2.70",
    "@radix-ui/react-slot": "^1.2.4",
    "@streamdown/code": "^1.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "cloudflared": "^0.5.0",
    "clsx": "^2.1.1",
    "hono": "^4.7.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitejs/plugin-react": "^4.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
